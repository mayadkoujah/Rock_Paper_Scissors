import random
moves = {'Rock': 1, 'Paper': 2 , 'Scissors': 3}

def rock():
    if player_move == 'Rock' and computer == 'Scissors':
        print('Rock beat scissors')
        return player_move
    elif computer == 'Rock' and player_move == 'Scissors':
        print('Rock beat scissors')
        return computer

def paper():
    if player_move == 'Paper' and computer == 'Rock':
        print('Paper beat Rock')
        return player_move
    if computer == 'Paper' and player_move == 'Rock':
        print('Paper beat Rock')
        return computer

def scissors():
    if player_move == 'Scissors' and computer == 'Paper':
        print('Paper beat Scissors')
        return player_move
    elif computer == 'Scissors' and player_move == 'Paper':
        print('Paper beat Scissors')
        return computer

def tie():
    if player_move == computer:
        print('ITS A TIE!!!')

def get_winner(player_move, computer):
    global player_score, computer_score
    winner = rock() or paper() or scissors() or tie()
    if winner == player_move:
        player_score += 1
        return player_move
    elif winner == computer:
        computer_score += 1
        return computer

player_score = 0
computer_score = 0
rounds = int(input("Enter how many rounds you would like to play: "))

for i in range(rounds):
    print(f'round: {i+1} out of {rounds}')
    while True:
        num = random.randint(1, 3)
        if num == 1: computer = 'Rock'
        elif num == 2: computer = 'Paper'
        elif num == 3: computer = 'Scissors'

        player_move = input("Player chooses rock (1), paper (2), or scissors (3): ").capitalize()

        if player_move == '1': player_move = 'Rock'
        elif player_move == '2': player_move = 'Paper'
        elif player_move == '3': player_move = 'Scissors'

        print('computer said:', computer)

        winner = get_winner(player_move, computer)
        print()
        print(f'winner: {winner}')
